# 复制此文件为 .dev.vars，填入你的真实密钥
# .dev.vars 已在 .gitignore 中，不会提交到 git

APP_PASSWORD = "your-password-here"
SENSENOVA_API_KEY = "your-sensenova-api-key"
FEISHU_APP_ID = "your-feishu-app-id"
FEISHU_APP_SECRET = "your-feishu-app-secret"
FEISHU_BASE_APP_TOKEN = "your-feishu-base-app-token"
FEISHU_BASE_TABLE_ID = "your-feishu-base-table-id"
